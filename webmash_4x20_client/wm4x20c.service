[Unit]
Description=Web 2.0 Mash client for 4x20 LCD
After=network.target webmash.service

[Service]
EnvironmentFile=-/etc/default/locale
# with rotary encoder and locale from /etc/default/locale
ExecStart=/usr/bin/webmash_4x20_client -n -i button@16 -r rotary@9

# with 4 buttons
#ExecStart=/usr/bin/webmash_4x20_client -n

ExecReload=/bin/kill -HUP $MAINPID
KillMode=process

[Install]
WantedBy=multi-user.target
